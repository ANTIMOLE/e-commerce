{
  "name": "@zenit/api-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Blackbox functional API tests for Zenit e-commerce (REST + tRPC)",
  "scripts": {
    "test:rest": "vitest run src/rest.test.ts  --reporter=verbose",
    "test:trpc": "vitest run src/trpc.test.ts  --reporter=verbose",
    "test:all": "vitest run                   --reporter=verbose",
    "test:watch": "vitest                        --reporter=verbose",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "axios-cookiejar-support": "^5.0.0",
    "dotenv": "^16.4.7",
    "tough-cookie": "^4.1.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/tough-cookie": "^4.0.5",
    "@vitest/ui": "^1.6.1",
    "typescript": "^5.5.4",
    "vitest": "^1.6.1"
  }
}

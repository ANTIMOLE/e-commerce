{
  "name": "backend-trpc",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child -r tsconfig-paths/register src/server.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/server.js",
    "test:unit": "vitest --config vitest.unit.config.ts run",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:coverage": "vitest --config vitest.unit.config.ts run --coverage"

  },
  "dependencies": {
    "@ecommerce/shared": "workspace:*",
    "@trpc/server": "^11.10.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "rimraf": "^6.1.3",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}

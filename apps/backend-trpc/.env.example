# NODE_ENV=development
# PORT=4001

# DATABASE_URL="postgresql://postgres:@localhost:5432/ecommerce_db"

# JWT_SECRET="DyeZe51(!{H<dHmCvtG>5FGq0:Vn-z_^oy-96oMQOF&z4CR,+9A<ky,2)DXLM>{J,#Ur3<TtWY4eVGqzShD.rw"
# JWT_REFRESH_SECRET="!??-#|<EbySBpxT7^Yd#s|H9]GGl.zLY[T6RlEzaDkwc2#(;xe%{c6qnR9k.-GEMU!Z)[m3#%OZ4BG|Ln9$YNJ"
# JWT_EXPIRY=1h
# JWT_REFRESH_EXPIRY=7d

# FRONTEND_URL=http://localhost:3000


import { z } from "zod";
import dotenv from "dotenv";

dotenv.config();

const envSchema = z.object({
  NODE_ENV:             z.enum(["development", "production", "test"]).default("development"),
  PORT:                 z.coerce.number().default(4001),
  DATABASE_URL:         z.string().min(1, "DATABASE_URL is required"),
  JWT_SECRET:           z.string().min(32, "JWT_SECRET must be at least 32 chars"),
  JWT_REFRESH_SECRET:   z.string().min(32, "JWT_REFRESH_SECRET must be at least 32 chars"),
  JWT_EXPIRY:           z.string().default("1h"),
  JWT_REFRESH_EXPIRY:   z.string().default("7d"),
  FRONTEND_URL:         z.string().default("http://localhost:3000"),
  // Research flag: mirror REST auth middleware DB lookup behavior
  // false (default) = stateless JWT-only — natural tRPC behavior
  // true            = DB lookup per request — equalized with REST for fair comparison
  AUTH_DB_VALIDATION:   z.coerce.boolean().default(false),
});

const parsed = envSchema.safeParse(process.env);

if (!parsed.success) {
  console.error("❌ Invalid environment variables:");
  console.error(parsed.error.flatten().fieldErrors);
  process.exit(1);
}

export const env = parsed.data;

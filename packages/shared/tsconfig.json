{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["ES2020"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "types": ["node"]   // ← tambah ini
  },
  "include": ["src/**/*", "prisma/**/*"],   // ← tambah prisma/**/*
  "exclude": ["node_modules", "dist", "generated", "prisma/cek-image.ts", "prisma/fix-image.ts", "prisma/fix-stock.ts"]
}
